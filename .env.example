DEBUG=1
SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=

PROXMOX_BASE_URL=https://proxmox.example/api
PROXMOX_TOKEN_ID=user@pve!token
PROXMOX_TOKEN_SECRET=replace-me
PROXMOX_TLS_VERIFY=0
PROXMOX_NODE=pve
PROXMOX_STORAGE_POOL=local-lvm
PROXMOX_ISO_STORAGE_POOL=local

AD_LDAP_HOST=ad.example.local
AD_LDAP_PORT=389
AD_LDAP_USE_SSL=0
AD_LDAP_CONNECT_TIMEOUT=1
AD_UPN_SUFFIX=example.local
AD_BASE_DN=DC=example,DC=local

TEMPLATE_CREATION_POLICY=allow_all
TEMPLATE_BUILD_WORKDIR=/var/lib/capstone/jobs
TEMPLATE_BUILD_POLL_SECONDS=5
TEMPLATE_BUILD_MAX_TIMEOUT_SEC=10800
TEMPLATE_BUILD_HEARTBEAT_SECONDS=15
TEMPLATE_BUILD_STALE_AFTER_SECONDS=900
TEMPLATE_BUILD_CONCURRENCY=1
PACKER_BIN=/usr/bin/packer
PACKER_ISO_TOOL=xorriso
PACKER_CACHE_DIR=/var/lib/capstone/packer-cache
PACKER_PROXMOX_PLUGIN_SOURCE=github.com/hashicorp/proxmox
PACKER_PROXMOX_PLUGIN_VERSION=>= 1.1.0
PACKER_NAS_ROOT=/mnt/capstone-nas
PACKER_NAS_ISO_DIR=/mnt/capstone-nas/isos
PACKER_NAS_ARCHIVE_DIR=/mnt/capstone-nas/archive
PACKER_JOBS_HOST_PATH=/srv/capstone/packer-jobs
PACKER_CACHE_HOST_PATH=/srv/capstone/packer-cache
PACKER_NAS_HOST_PATH=/mnt/capstone-nas
ALLOW_PRIVATE_TEMPLATE_ASSET_URLS=1
